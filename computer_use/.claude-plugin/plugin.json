{
  "$schema": "https://json.schemastore.org/claude-code-plugin-manifest.json",
  "name": "computer-use",
  "displayName": "Computer Use",
  "version": "0.1.0",
  "description": "Local Windows computer-use plugin exposed through the repository MCP stdio adapter.",
  "author": {
    "name": "computer_use project"
  },
  "license": "UNLICENSED",
  "keywords": [
    "claude-code",
    "computer-use",
    "windows",
    "mcp"
  ],
  "mcpServers": {
    "computer-use": {
      "command": "node",
      "args": [
        "./dist/src/adapters/claude-code/mcp-entrypoint.js"
      ],
      "cwd": "${CLAUDE_PLUGIN_ROOT}"
    }
  }
}
